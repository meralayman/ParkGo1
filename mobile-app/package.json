{
  "name": "mobile-app",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start --localhost --port 8081",
    "start:clear": "expo start --localhost -c --port 8081",
    "start:lan": "expo start --port 8081",
    "start:tunnel": "expo start --tunnel --port 8081",
    "open:android": "powershell -ExecutionPolicy Bypass -File ./scripts/open-android.ps1",
    "open:android:8081": "powershell -ExecutionPolicy Bypass -File ./scripts/open-android.ps1 -Port 8081",
    "android": "expo start --localhost --port 8081",
    "ios": "expo start --ios --port 8081",
    "start:if-busy": "expo start --localhost -c --port 8084"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.15.11",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.12",
    "axios": "^1.16.0",
    "expo": "~54.0.33",
    "expo-camera": "~17.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-maps": "1.20.1",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1"
  },
  "private": true,
  "devDependencies": {
    "@expo/ngrok": "^4.1.3"
  }
}
