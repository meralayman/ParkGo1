# Copy to `.env`, then: npx expo start -c

# Physical phone (Expo Go) — PC Wi‑Fi IPv4 from ipconfig
EXPO_PUBLIC_API_LAN_HOST=192.168.1.51
EXPO_PUBLIC_API_BASE_URL=http://192.168.1.51:5000

# Android emulator uses 10.0.2.2 automatically (no change needed if LAN lines above are set)

# Override emulator URL only if needed:
# EXPO_PUBLIC_API_ANDROID_EMULATOR_URL=http://10.0.2.2:5000
