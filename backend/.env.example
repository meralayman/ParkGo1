NODE_ENV=development
PORT=5000
HOST=0.0.0.0
TRUST_PROXY=0

DATABASE_URL=postgresql://parkgo_user:YOUR_PASSWORD@127.0.0.1:5432/parkgo_db

JWT_ACCESS_SECRET=change-me-to-a-long-random-string
JWT_REFRESH_DAYS=7

# Production: comma-separated HTTPS origins only (no wildcards)
# CORS_ORIGIN=https://your-domain.com,https://www.your-domain.com

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# Optional default gatekeeper account (web /gatekeeper, mobile gatekeeper tabs)
GATEKEEPER_EMAIL=gatekeeper@example.com
GATEKEEPER_PASSWORD=change-me

# Physical gate camera + barrier (POST /gate/device/scan)
# Generate a long random string (min 16 chars). Same value on gate controller + backend.
GATE_DEVICE_API_KEY=change-me-to-a-long-random-gate-device-key
GATE_DEVICE_ID=gate-entry-1

# Gate agent (runs on Raspberry Pi next to camera) — see deploy/GATE-DEVICE.md
# PARKGO_API_URL=http://your-server:5000
# GATE_AGENT_PORT=8765
# GATE_RELAY_OPEN_SCRIPT=/path/to/open-barrier.sh
# GATE_RELAY_DENY_SCRIPT=/path/to/deny-beep.sh
# GATE_OPEN_PULSE_MS=3000

# Check-in window (minutes after scheduled start before no-show cancel)
# ARRIVAL_WINDOW_MINUTES=20
# EARLY_CHECKIN_MINUTES=60
# QR_EXPIRE_HOURS_AFTER_END=3
