PORT=5000
DATABASE_URL=postgresql://parkgo_user:Parkgo123@localhost:5432/parkgo_db

# JWT — edit these; access tokens are signed with JWT_ACCESS_SECRET (or JWT_SECRET if unset)
# Refresh tokens are random strings stored in the DB, not a JWT; there is no JWT_REFRESH_SECRET
JWT_SECRET=parkgo_access_secret_12345
JWT_ACCESS_SECRET=another_super_secure_secret_even_longer_987654
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_DAYS=7

# Admin user (created on server start if not already in DB)
ADMIN_EMAIL=admin@parkgo.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin123

