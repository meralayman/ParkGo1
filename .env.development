# Loaded automatically when you run `npm start` (development only).
# Local API — HTTP only; backend must be on port 5000.
REACT_APP_API_BASE_URL=https://127.0.0.1:5000

# With "proxy" in package.json, CRA enables webpack-dev-server host checks — ngrok URLs then show "Invalid Host header".
# See: https://github.com/facebook/create-react-app/issues/2271
DANGEROUSLY_DISABLE_HOST_CHECK=true
